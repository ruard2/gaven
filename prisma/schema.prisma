generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Admin {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
  organizations Organization[]
}

model Organization {
  id               String   @id @default(cuid())
  name             String
  slug             String   @unique
  publicCode       String   @unique
  organizationType String
  place            String?
  logoUrl          String?
  primaryColor     String   @default("#2563eb")
  welcomeText      String?
  contactEmail     String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
  adminId          String
  admin            Admin    @relation(fields: [adminId], references: [id])
  vacancies        Vacancy[]
  participants     Participant[]
  applications     Application[]
  inviteTokens     InviteToken[]
  coordinators     Coordinator[]
}

model Coordinator {
  id              String   @id @default(cuid())
  organizationId  String
  organization    Organization @relation(fields: [organizationId], references: [id])
  name            String
  email           String
  passwordHash    String?
  inviteToken     String?  @unique
  inviteExpiresAt DateTime?
  status          String   @default("invited")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  vacancies       Vacancy[]
  resetTokens     CoordinatorResetToken[]
  rosters         Roster[]
  coCoordinating  CoCoordinator[]
}

model Roster {
  id            String        @id @default(cuid())
  coordinatorId String
  coordinator   Coordinator   @relation(fields: [coordinatorId], references: [id], onDelete: Cascade)
  vacancyId     String?
  vacancy       Vacancy?      @relation(fields: [vacancyId], references: [id])
  title         String
  reminderDays  Int           @default(3)
  senderName    String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
  entries       RosterEntry[]
}

model RosterEntry {
  id           String    @id @default(cuid())
  rosterId     String
  roster       Roster    @relation(fields: [rosterId], references: [id], onDelete: Cascade)
  name         String
  email        String?
  date         DateTime?
  role         String?
  notes        String?
  reminderSent Boolean   @default(false)
  createdAt    DateTime  @default(now())
}

model CoordinatorResetToken {
  id            String      @id @default(cuid())
  coordinatorId String
  coordinator   Coordinator @relation(fields: [coordinatorId], references: [id], onDelete: Cascade)
  token         String      @unique
  expiresAt     DateTime
  usedAt        DateTime?
  createdAt     DateTime    @default(now())
}

model Vacancy {
  id                 String   @id @default(cuid())
  organizationId     String
  organization       Organization @relation(fields: [organizationId], references: [id])
  coordinatorId      String?
  coordinator        Coordinator? @relation(fields: [coordinatorId], references: [id])
  title              String
  slug               String?
  category           String
  shortDescription   String
  longDescription    String?
  whyValuable        String?
  concreteTasks      String?
  firstStep          String?
  contactPersonName  String
  contactPersonEmail String
  status             String   @default("active")
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  qualityWeights     VacancyQualityWeight[]
  applications       Application[]
  proposals          VacancyProposal[]
  memberships        VacancyMembership[]
  rosters            Roster[]
  pageSections       VacancyPageSection[]
  coCoordinators     CoCoordinator[]
}

model VacancyPageSection {
  id        String   @id @default(cuid())
  vacancyId String
  vacancy   Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  type      String   @default("text")
  title     String
  content   String?
  url       String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CoCoordinator {
  id            String      @id @default(cuid())
  vacancyId     String
  vacancy       Vacancy     @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  coordinatorId String
  coordinator   Coordinator @relation(fields: [coordinatorId], references: [id], onDelete: Cascade)
  confirmToken  String      @unique
  status        String      @default("pending")
  createdAt     DateTime    @default(now())

  @@unique([vacancyId, coordinatorId])
}

model VacancyProposal {
  id           String   @id @default(cuid())
  vacancyId    String
  vacancy      Vacancy  @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  proposedData String
  editorName   String?
  status       String   @default("pending")
  createdAt    DateTime @default(now())
}

model VacancyMembership {
  id            String      @id @default(cuid())
  participantId String
  participant   Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)
  vacancyId     String
  vacancy       Vacancy     @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  description   String?
  createdAt     DateTime    @default(now())

  @@unique([participantId, vacancyId])
}

model InviteToken {
  id             String       @id @default(cuid())
  token          String       @unique
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  label          String?
  expiresAt      DateTime?
  createdAt      DateTime     @default(now())
}

model VacancyQualityWeight {
  id        String  @id @default(cuid())
  vacancyId String
  vacancy   Vacancy @relation(fields: [vacancyId], references: [id], onDelete: Cascade)
  qualityId String
  weight    Int     @default(50)

  @@unique([vacancyId, qualityId])
}

model Participant {
  id             String   @id @default(cuid())
  organizationId String
  organization   Organization @relation(fields: [organizationId], references: [id])
  name           String
  email          String
  phone          String?
  createdAt      DateTime @default(now())
  profile        ParticipantProfile?
  applications   Application[]
  memberships    VacancyMembership[]
}

model ParticipantProfile {
  id                   String   @id @default(cuid())
  participantId        String   @unique
  participant          Participant @relation(fields: [participantId], references: [id])
  workExperienceScores String   @default("[]")
  selectedQualityScores String  @default("[]")
  negativePreferences  String   @default("[]")
  completedAt          DateTime?
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
}

model Application {
  id               String   @id @default(cuid())
  organizationId   String
  organization     Organization @relation(fields: [organizationId], references: [id])
  participantId    String
  participant      Participant @relation(fields: [participantId], references: [id])
  vacancyId        String
  vacancy          Vacancy @relation(fields: [vacancyId], references: [id])
  responseType     String
  message          String?
  availabilityNote String?
  firstStepChoice  String?
  status           String   @default("new")
  createdAt        DateTime @default(now())
}
